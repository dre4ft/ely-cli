# Ely CLI Configuration
# Copy to ~/.ely/config.yaml or ./ely.yaml

ely:
  dir: ~/.ely              # Base directory for all Ely data (skills, memory, diary, contexts, history)

provider:
  type: openai           # openai, ollama, lmstudio
  model: gpt-4o-mini
  url: https://api.openai.com/v1
  api_key: ""            # or set OPENAI_API_KEY env var

pro_provider:
  type: openai
  model: gpt-4o
  url: https://api.openai.com/v1
  api_key: ""

agent:
  max_turns: 8
  name: Ely
  language: fr

memory:
  compaction_rounds: 10

tools:
  # Workspace racine — tous les chemins de fichiers sont relatifs à ce répertoire
  workspace: "."         # ou chemin absolu: /home/user/projects
  # Bash sandbox: "direct" (machine hôte) ou "docker" (conteneur isolé)
  # L'agent NE PEUT PAS changer ce réglage au runtime
  bash_sandbox: direct
  # Outils désactivés (séparés par des virgules). Laisse vide pour tout activer.
  # Liste complète: bash, bash_batch, read_file, write_file, list_directory,
  #   grep, web_search, web_fetch, http_request, http_batch, socket_raw,
  #   diary_add, diary_list, diary_search, diary_get,
  #   task, task_parallel,
  #   skill_create, skill_add_tool, skill_add_reference, skill_add_asset
  # Exemples utiles:
  #   disabled: "bash, bash_batch"             → agent sans shell
  #   disabled: "write_file"                   → agent read-only
  #   disabled: "task, task_parallel"          → pas de sous-agents
  disabled: ""
  fs_sandbox: false   

# MCP (Model Context Protocol) servers — optional
# Tools from these servers are auto-discovered and merged into the agent's toolset.
mcp:
  servers: []
  # Example stdio server:
  # - name: filesystem
  #   command: npx
  #   args: ["-y", "@modelcontextprotocol/server-filesystem", "/allowed/path"]
  #   env: {}
  #
  # Example remote SSE server:
  # - name: remote-api
  #   url: https://mcp.example.com/sse
  #   transport: sse
  #   headers:
  #     Authorization: "Bearer xxx"
